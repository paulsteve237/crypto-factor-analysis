    ]

    # Création de l'objet principal d'analyse factorielle.
    fa = FactorAnalysis(
        tickers=tickers,
        start="2010-01-01",
        end=None,
        return_method="log"
    )

    # ========================================================
    # Téléchargement des données
    # ========================================================
    fa.load_data()

    # Configuration des facteurs à construire.
    configs = [
        FactorConfig(name="MKT", factor_type="market", method="equal_weight"),
        FactorConfig(name="PC", factor_type="pca", n_components=3),
        FactorConfig(name="MOM_30", factor_type="momentum", window=30),
        FactorConfig(name="VOL_30", factor_type="volatility", window=30),
        FactorConfig(name="DISP", factor_type="dispersion")
    ]

    # ========================================================
    # Construction des facteurs
    # ========================================================
    fa.build_factors(configs)

    # ========================================================
    # Choix des assets et des facteurs à utiliser
    # ========================================================

    # sélectionner quelques actifs seulement.
    assets = ["BTC-USD", "ETH-USD", "SOL-USD"]
    assets = tickers
    # Facteurs utilisés dans la régression.    
    factors_to_use = ["PC1","PC2","PC3","MOM_30","DISP","VOL_30"]
    
    
    # ========================================================
    # OLS REGRESSION
    # ========================================================

    ols_results = fa.run_regression(
        assets=assets,
        factors_to_use=factors_to_use,
        method="OLS"
    )

    print("\nOLS BETAS:")
    print(ols_results.get_betas())

    # ========================================================
    # ROLLING WINDOW REGRESSION
    # ========================================================

    rolling_results = fa.run_regression(
        assets=assets,
        factors_to_use=factors_to_use,
        method="ROLLING",
        window=30
    )

    print("\nROLLING BETAS FOR BTC:")
    rolling_results.get_betas("BTC-USD").plot()
    ols_results.get_alphas()
